<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="container mt-5 pt-5">

  <!-- Welcome -->
  <div class="row justify-content-center">
    <div class="col-md-8">
      <article>
        <h1 class="mb-4">Welcome to Ju Fufu Mains</h1>
        <!-- Add your own welcome content here -->
      </article>
    </div>
  </div>

  <!-- Announcements -->
  <% if (announcements.length > 0) { %>
  <div class="row justify-content-center mt-5">
    <div class="col-md-8">
      <h2 class="mb-3">Announcements</h2>
      <% announcements.forEach(function(a) { %>
        <div class="card mb-3 <%= a.pinned ? 'border-warning' : '' %>">
          <div class="card-body">
            <% if (a.pinned) { %>
              <span class="badge bg-warning text-dark mb-2">Pinned</span>
            <% } %>
            <h5 class="card-title"><%= a.title %></h5>
            <p class="card-text"><%= a.content %></p>
            <small class="text-muted announcement-date" data-date="<%= a.createdAt.toISOString() %>"></small>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

</main>

<%- include('partials/footer') %>