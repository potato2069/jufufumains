<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main>
  <h1>Builds</h1>

  <% if (builds.length === 0) { %>
    <p>No builds posted yet.</p>
  <% } else { %>
    <% builds.forEach(function(b) { %>
      <div>
        <% if (b.recommended) { %><span>Recommended</span><% } %>
        <h2><%= b.name %></h2>
        <p><%= b.description %></p>

        <p>W-Engine: <%= b.wEngine %></p>

        <p>Drive Discs:</p>
        <ul>
          <% b.driveDiscs.forEach(function(disc) { %>
            <li><%= disc %></li>
          <% }) %>
        </ul>

        <p>Main Stats:</p>
        <ul>
          <% Object.entries(b.mainStats).forEach(function([slot, stat]) { %>
            <li><%= slot %>: <%= stat %></li>
          <% }) %>
        </ul>

        <p>Skill Priority: <%= b.skills.join(' > ') %></p>

        <% if (b.notes) { %>
          <p>Notes: <%= b.notes %></p>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</main>

<%- include('partials/footer') %>