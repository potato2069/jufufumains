# Application Configuration
PORT=3000
APP_BASE_URL=http://localhost:3000

# Generate a Secret. Without it, it won't run.
# Run:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# Deployment toggles
# Leave these false while developing or temporarily exposing on HTTP.
# Once Nginx + TLS is in front, set both to true and update APP_BASE_URL to https://
TRUST_PROXY=false
SESSION_COOKIE_SECURE=false