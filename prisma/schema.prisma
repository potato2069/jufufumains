generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Build {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  wEngine     String
  driveDiscs  String   // JSON array string
  mainStats   String   // JSON object string
  subStats    String   // JSON array string
  skills      String   // JSON array string
  notes       String?
  recommended Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("user")  // "admin" or "user"
  createdAt DateTime @default(now())
}
